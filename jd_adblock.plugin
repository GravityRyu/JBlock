#!name=JD AdBlock
#!desc=Block JD iOS ads/popups from local capture. Tested against JD4iPhone 15.8.0 traffic.
#!author=Codex
#!date=2026-06-10

[Rule]
# DSP ad feed observed as im-x.jd.com/dsp/np.
DOMAIN,im-x.jd.com,REJECT

# Home/search ad delivery observed in this capture.
DOMAIN,sh.jd.com,REJECT

# Telemetry/noise domains observed in this capture.
DOMAIN,mars.jd.com,REJECT
DOMAIN,perf.m.jd.com,REJECT
DOMAIN,anti-sdk-report.m.jd.com,REJECT
DOMAIN,ex.m.jd.com,REJECT
DOMAIN,mllog.jd.com,REJECT

[URL Rewrite]
# Cart/activity egg animations and promotion dialog assets observed in the capture.
^https?:\/\/storage\.360buyimg\.com\/(?:sunglasses-push-msg\/.*\.json|appcartsoa\/(?:client\/cart_egg_entry|cart_taohuadao_light|finalrixiao)\.json|app\.m\.jd\.com\/lottie\/scs_jingEgg(?:Halo|FireWorks)\.json|mobileskin\/an\d+\.json) _ reject
^https?:\/\/storage\.360buyimg\.com\/appcartsoa\/must_have_dialog_add\.png _ reject

# Message-center TN/ad feed requests. The visible images load later from m.360buyimg.com with Referer: tn_message.
^https?:\/\/api\.m\.jd\.com\/client\.action\?.*functionId=recommendShopV15100 _ reject
^https?:\/\/sh\.jd\.com\/(?:d(?:\?|$)|j\/) _ reject

# XView popup / right-floating-logo / top-banner assets observed with Referer: download_image_xview_*.
^https?:\/\/m15\.360buyimg\.com\/mobilecms\/jfs\/t1\/438105\/30\/1519\/25976\/6a0ee245F0ffa0abc\/00290900909a97ce\.png\.webp(?:[?!].*)?$ _ reject
^https?:\/\/(?:m|img12|img20)\.360buyimg\.com\/.*\/91bc616e0466a56a\.png(?:[?!].*)?$ _ reject
^https?:\/\/(?:m|img12|img20)\.360buyimg\.com\/.*\/b49e6c18dc93b644\.png(?:[?!].*)?$ _ reject
^https?:\/\/(?:m|img12|img20)\.360buyimg\.com\/.*\/013a0d80d89d0e82\.png(?:[?!].*)?$ _ reject
^https?:\/\/(?:m|img12|img20)\.360buyimg\.com\/.*\/47c681638b906b03\.png(?:[?!].*)?$ _ reject
^https?:\/\/(?:m|img12|img20)\.360buyimg\.com\/.*\/ea22c154eb10e17b\.png(?:[?!].*)?$ _ reject
